# OPENROUTER_API_KEY: Default API key for the Prompt Optimizer (via OpenRouter).
# SERVER-SIDE ONLY — read by api/analyze.ts (a Vercel serverless function) and never bundled
# into client JS. Set this in Vercel env vars. Users can override it with their own key in
# Settings, in which case the browser calls OpenRouter directly with their key instead.
OPENROUTER_API_KEY="sk-or-..."

# OPENROUTER_MODEL: OpenRouter model id used by the Prompt Optimizer (e.g. "openai/gpt-4o-mini",
# "anthropic/claude-3.5-sonnet"). Optional — defaults to "openai/gpt-4o-mini" if unset.
OPENROUTER_MODEL="openai/gpt-4o-mini"

# OPENAI_API_KEY: Legacy — kept for reference, not actively used.
OPENAI_API_KEY="MY_OPENAI_API_KEY"

# APP_URL: The URL where this app is hosted.
APP_URL="MY_APP_URL"
