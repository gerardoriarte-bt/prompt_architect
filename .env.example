# OPENROUTER_API_KEY: Default API key for the Prompt Optimizer (via OpenRouter).
# Set this in Vercel env vars. Users can override it with their own key in Settings.
OPENROUTER_API_KEY="sk-or-..."

# OPENAI_API_KEY: Legacy — kept for reference, not actively used.
OPENAI_API_KEY="MY_OPENAI_API_KEY"

# APP_URL: The URL where this app is hosted.
APP_URL="MY_APP_URL"
